{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "nix": {
    "enabled": true
  },
  "customManagers": [
    {
      "description": "opencode version in packages/opencode.nix",
      "customType": "regex",
      "fileMatch": ["^packages/opencode\\.nix$"],
      "matchStrings": [
        "# renovate: datasource=github-releases depName=anomalyco/opencode\\n\\s*version = \"(?<currentValue>[\\d.]+)\";"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "anomalyco/opencode",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "description": "rtk version in packages/rtk.nix",
      "customType": "regex",
      "fileMatch": ["^packages/rtk\\.nix$"],
      "matchStrings": [
        "# renovate: datasource=github-releases depName=rtk-ai/rtk\\n\\s*version = \"(?<currentValue>[\\d.]+)\";"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "rtk-ai/rtk",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "description": "@anthropic-ai/claude-code npm version in flake.nix",
      "customType": "regex",
      "fileMatch": ["^flake\\.nix$"],
      "matchStrings": [
        "# renovate: datasource=npm depName=@anthropic-ai/claude-code\\n\\s*claudeCodeVersion = \"(?<currentValue>[\\d.]+)\";"
      ],
      "datasourceTemplate": "npm",
      "depNameTemplate": "@anthropic-ai/claude-code"
    }
  ],
  "packageRules": [
    {
      "description": "Group custom derivation updates (opencode, rtk, claude-code)",
      "groupName": "container-deps",
      "matchManagers": ["custom.regex"]
    },
    {
      "description": "Group Nix flake input updates into a single PR",
      "groupName": "nix",
      "matchManagers": ["nix"]
    },
    {
      "description": "Group GitHub Actions version updates into a single PR",
      "groupName": "github-actions",
      "matchManagers": ["github-actions"]
    }
  ]
}
